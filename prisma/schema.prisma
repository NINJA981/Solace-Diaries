datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  entries          JournalEntry[]
  memoryFragments  MemoryFragment[]
  proactivePrompts ProactivePrompt[]
}

model JournalEntry {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String        @db.Text
  mood      String
  tags      String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  vectors   VectorRecord[]
  memorySources MemoryFragmentSource[]
}

model VectorRecord {
  id        String       @id @default(uuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  vector    Unsupported("vector(768)")?
  createdAt DateTime     @default(now())
}

model MemoryFragment {
  id               String                 @id @default(uuid())
  userId           String
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         String
  content          String                 @db.Text
  strength         Int                    @default(1)
  status           String                 @default("active")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  sourceEntries    MemoryFragmentSource[]
  proactivePrompts ProactivePrompt[]
}

model MemoryFragmentSource {
  id               String         @id @default(uuid())
  memoryFragmentId String
  memoryFragment   MemoryFragment @relation(fields: [memoryFragmentId], references: [id], onDelete: Cascade)
  entryId          String
  entry            JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
}

model ProactivePrompt {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  memoryFragmentId String?
  memoryFragment   MemoryFragment? @relation(fields: [memoryFragmentId], references: [id], onDelete: SetNull)
  promptText       String          @db.Text
  triggerType      String
  scheduledFor     DateTime
  isDelivered      Boolean         @default(false)
  deliveredAt      DateTime?
  userResponse     String?         @db.Text
  createdAt        DateTime        @default(now())
}
